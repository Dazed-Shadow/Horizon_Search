# Get a free API key at https://sam.gov/profile/details
# Registration takes ~15 minutes; key activates within 24 hours.
SAM_GOV_API_KEY=your_sam_gov_api_key_here

# Optional: override allowed frontend origins (comma-separated)
CORS_ORIGINS=http://localhost:5173

# ── Notion sync (optional — needed to run scripts/notion_sync.py) ─────────────
# 1. Go to notion.so/my-integrations → "New integration" → copy the secret token
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 2. Open your Horizon Search root page in Notion → click ••• → Connections → MR_C-HANDS
#    Copy the 32-char hex ID from the URL: notion.so/<workspace>/<page-title>-<THIS_PART>
NOTION_ROOT_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
